{
  "name": "shoppyglobe-backend",
  "version": "1.0.0",
  "description": "ShoppyGlobe Backend API - E-commerce Project (Node.js, Express, MongoDB)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "clean": "rm -rf node_modules package-lock.json",
    "clean:win": "rmdir /s /q node_modules && del package-lock.json",
    "reinstall": "npm run clean && npm install",
    "reinstall:win": "npm run clean:win && npm install"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "ecommerce",
    "api",
    "backend",
    "rest-api"
  ],
  "author": "Ridhesh",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
